{
  "$schema": "https://raw.githubusercontent.com/strapi/strapi/main/packages/core/content-type-builder/content-type-schema.json",
  "info": {
    "singularName": "guide",
    "pluralName": "guides",
    "displayName": "Guide",
    "description": "Guide de séjour — une entrée par propriété (données dynamiques)"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "description": "Nom de la propriété (ex: Le Saint Georges)"
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "address": {
      "type": "string",
      "required": true
    },
    "mapsUrl": {
      "type": "string",
      "required": true
    },
    "accessCode": {
      "type": "string",
      "required": true,
      "private": true,
      "description": "Code d'accès au guide (saisi par le voyageur sur la page login)"
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "checkIn": {
      "type": "string",
      "required": true,
      "default": "Dès 17h00"
    },
    "checkOut": {
      "type": "string",
      "required": true,
      "default": "Avant 11h00"
    },
    "codeBuilding": {
      "type": "string",
      "required": true
    },
    "codeKeyBox": {
      "type": "string",
      "required": true
    },
    "wifiSsid": {
      "type": "string"
    },
    "wifiPassword": {
      "type": "string"
    },
    "whatsapp": {
      "type": "string",
      "required": true,
      "description": "Numéro WhatsApp du concierge (format international)"
    },
    "keyNote": {
      "type": "text",
      "description": "Note courte sous les infos rapides (ex: La clé ouvre aussi le local à ski)"
    },

    "arriveeTip": {
      "type": "text",
      "description": "Astuce affichée en haut de la section Arrivée"
    },
    "arriveeSteps": {
      "type": "component",
      "repeatable": true,
      "component": "guide.step"
    },

    "departCheckoutMessage": {
      "type": "text"
    },
    "departChecklist": {
      "type": "json",
      "description": "Array de strings — items de la checklist de départ"
    },

    "parkingWinterNote": {
      "type": "text"
    },
    "parkingPrivateTitle": {
      "type": "string"
    },
    "parkingPrivateDescription": {
      "type": "text"
    },
    "parkingPrivateImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "parkingPublicTitle": {
      "type": "string"
    },
    "parkingPublicDescription": {
      "type": "text"
    },

    "logementIntro": {
      "type": "text"
    },
    "logementItems": {
      "type": "component",
      "repeatable": true,
      "component": "guide.logement-item"
    },

    "dechets": {
      "type": "component",
      "repeatable": true,
      "component": "guide.dechets-block"
    },

    "regionBlocks": {
      "type": "component",
      "repeatable": true,
      "component": "guide.region-block"
    },

    "regles": {
      "type": "component",
      "repeatable": true,
      "component": "guide.rule"
    },

    "emergencyUrgences": {
      "type": "string",
      "default": "Urgences 144"
    },
    "emergencyUrgencesTel": {
      "type": "string",
      "default": "+41144"
    },
    "emergencyPolice": {
      "type": "string",
      "default": "Police 117"
    },
    "emergencyPoliceTel": {
      "type": "string",
      "default": "+41117"
    },
    "emergencyPompiers": {
      "type": "string",
      "default": "Pompiers 118"
    },
    "emergencyPompiersTel": {
      "type": "string",
      "default": "+41118"
    }
  },

  "__components": {
    "guide.step": {
      "info": { "displayName": "Step", "description": "Étape numérotée (arrivée)" },
      "attributes": {
        "title": { "type": "string", "required": true },
        "description": { "type": "text" },
        "images": { "type": "media", "multiple": true, "allowedTypes": ["images"] }
      }
    },
    "guide.logement-item": {
      "info": { "displayName": "Logement Item", "description": "Élément accordion logement" },
      "attributes": {
        "title": { "type": "string", "required": true },
        "description": { "type": "text", "required": true },
        "images": { "type": "media", "multiple": true, "allowedTypes": ["images"] }
      }
    },
    "guide.dechets-block": {
      "info": { "displayName": "Déchets Block", "description": "Bloc section déchets" },
      "attributes": {
        "title": { "type": "string", "required": true },
        "paragraphs": { "type": "json", "description": "Array de strings (HTML autorisé)" },
        "image": { "type": "media", "multiple": false, "allowedTypes": ["images"] }
      }
    },
    "guide.region-block": {
      "info": { "displayName": "Region Block", "description": "Bloc section région" },
      "attributes": {
        "title": { "type": "string", "required": true },
        "description": { "type": "text", "required": true },
        "image": { "type": "media", "multiple": false, "allowedTypes": ["images"] },
        "ctas": { "type": "json", "description": "Array of { label: string, url: string }" }
      }
    },
    "guide.rule": {
      "info": { "displayName": "Rule", "description": "Règle du règlement" },
      "attributes": {
        "title": { "type": "string", "required": true },
        "content": { "type": "text", "required": true }
      }
    }
  }
}

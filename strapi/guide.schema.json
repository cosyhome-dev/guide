{
  "info": {
    "singularName": "guide",
    "pluralName": "guides",
    "displayName": "Guide",
    "description": "Guide de séjour — une entrée par propriété"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true
    },
    "address": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "mapsUrl": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "accessCode": {
      "type": "string",
      "required": true,
      "private": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "heroImage": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "checkIn": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "checkOut": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "codeBuilding": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "codeKeyBox": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "wifiSsid": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "wifiPassword": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "keyNote": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },

    "gestionnaire": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::gestionnaire.gestionnaire",
      "inversedBy": "guides"
    },

    "arriveeTip": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "arriveeSteps": {
      "type": "component",
      "repeatable": true,
      "component": "guide.step"
    },

    "departCheckoutMessage": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "departChecklist": {
      "type": "component",
      "repeatable": true,
      "component": "guide.checklist-item"
    },

    "parkingWinterNote": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "parkingPrivateTitle": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "parkingPrivateDescription": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "parkingPrivateImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "parkingPublicTitle": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "parkingPublicDescription": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },

    "logementIntro": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "logementItems": {
      "type": "component",
      "repeatable": true,
      "component": "guide.logement-item"
    },

    "dechetsBlocks": {
      "type": "component",
      "repeatable": true,
      "component": "guide.dechets-block"
    },

    "regionBlocks": {
      "type": "component",
      "repeatable": true,
      "component": "guide.region-block"
    },

    "regles": {
      "type": "component",
      "repeatable": true,
      "component": "guide.rule"
    },

    "emergencyUrgences": {
      "type": "string",
      "default": "Urgences 144",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "emergencyUrgencesTel": {
      "type": "string",
      "default": "+41144",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "emergencyPolice": {
      "type": "string",
      "default": "Police 117",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "emergencyPoliceTel": {
      "type": "string",
      "default": "+41117",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "emergencyPompiers": {
      "type": "string",
      "default": "Pompiers 118",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "emergencyPompiersTel": {
      "type": "string",
      "default": "+41118",
      "pluginOptions": { "i18n": { "localized": false } }
    }
  }
}

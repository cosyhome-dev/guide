{
  "info": {
    "singularName": "static-content",
    "pluralName": "static-contents",
    "displayName": "Static Content",
    "kind": "singleType",
    "description": "Texte UI statique partagé entre tous les guides"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "loginTitle": { "type": "string", "required": true, "default": "Guide de séjour" },
    "loginDescription": { "type": "text", "required": true },
    "loginCodeLabel": { "type": "string", "default": "Code d'accès" },
    "loginCodePlaceholder": { "type": "string", "default": "Entrez votre code" },
    "loginSubmit": { "type": "string", "default": "Accéder au guide" },
    "loginNoCodePrefix": { "type": "string", "default": "Vous n'avez pas reçu de code ?" },
    "loginNoCodeLink": { "type": "string", "default": "Contactez votre concierge" },
    "loginNoCodeWhatsapp": { "type": "string", "default": "+41791234567", "pluginOptions": { "i18n": { "localized": false } } },
    "loginError": { "type": "string", "default": "Veuillez entrer votre code d'accès" },

    "navHome": { "type": "string", "default": "Accueil" },
    "navRules": { "type": "string", "default": "Règlement" },
    "navContact": { "type": "string", "default": "Contact" },
    "navRoute": { "type": "string", "default": "Itinéraire" },

    "homeWelcome": { "type": "string", "default": "Bienvenue" },
    "homeCheckIn": { "type": "string", "default": "Check-in" },
    "homeCheckOut": { "type": "string", "default": "Check-out" },
    "homeAccessCodes": { "type": "string", "default": "Codes d'accès" },
    "homeWifi": { "type": "string", "default": "WiFi" },

    "sectionBack": { "type": "string", "default": "Retour au guide" },
    "sectionNotFound": { "type": "string", "default": "Section introuvable" },
    "sectionOpenMaps": { "type": "string", "default": "Ouvrir dans Google Maps ↗" },
    "sectionStepLabel": { "type": "string", "default": "Étape" },

    "sectionArrivee": { "type": "string", "default": "Arrivée" },
    "sectionDepart": { "type": "string", "default": "Départ" },
    "sectionParking": { "type": "string", "default": "Parking" },
    "sectionLogement": { "type": "string", "default": "Le Logement" },
    "sectionDechets": { "type": "string", "default": "Déchets" },
    "sectionRegion": { "type": "string", "default": "Région" },
    "sectionRegles": { "type": "string", "default": "Règles" },

    "departCheckoutLabel": { "type": "string", "default": "Check-out" },
    "departChecklistTitle": { "type": "string", "default": "Checklist de départ" },

    "notFoundTitle": { "type": "string", "default": "404" },
    "notFoundMessage": { "type": "string", "default": "Page introuvable" },
    "notFoundLink": { "type": "string", "default": "Retour à l'accueil" },

    "altBrand": { "type": "string", "default": "CosyHome Conciergerie", "pluginOptions": { "i18n": { "localized": false } } },

    "formatBuilding": { "type": "string", "default": "Bâtiment : {value}" },
    "formatKeyBox": { "type": "string", "default": "Boîte à clé : {value}" },
    "formatPassword": { "type": "string", "default": "MDP : {value}" },

    "logoLight": { "type": "media", "multiple": false, "allowedTypes": ["images"], "pluginOptions": { "i18n": { "localized": false } } },
    "logoDark": { "type": "media", "multiple": false, "allowedTypes": ["images"], "pluginOptions": { "i18n": { "localized": false } } },
    "logoCircle": { "type": "media", "multiple": false, "allowedTypes": ["images"], "pluginOptions": { "i18n": { "localized": false } } },
    "logoCopyright": { "type": "media", "multiple": false, "allowedTypes": ["images"], "pluginOptions": { "i18n": { "localized": false } } }
  }
}
